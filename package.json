{
  "name": "mpc-platform",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @mpc/web dev",
    "build": "pnpm --filter @mpc/web build",
    "start": "pnpm --filter @mpc/web start",
    "lint": "pnpm --filter @mpc/web lint",
    "format": "pnpm --filter @mpc/web format",
    "test": "pnpm --filter @mpc/web test",
    "test:e2e": "pnpm --filter @mpc/web test:e2e",
    "db:generate": "pnpm --filter @mpc/web db:generate",
    "db:migrate": "pnpm --filter @mpc/web db:migrate",
    "db:seed": "pnpm --filter @mpc/web db:seed",
    "db:push": "pnpm --filter @mpc/web db:push"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "msw",
      "unrs-resolver"
    ]
  }
}